# ---------------------------------------------------------------------------
# Pitchdecker environment variables
# Copy this file to .env.local and fill in real values.
# ---------------------------------------------------------------------------

# MongoDB — pitchdecker database (decks, sections, candidates)
MONGODB_CONNECTION_STRING=

# Algolia — consultant directory search
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_CDN_BASE=

# Anthropic — AI panel (analysis, suggestions, chat)
ANTHROPIC_API_KEY=

# AssemblyAI — voice note transcription
ASSEMBLYAI_API_KEY=

# PostgreSQL (db_gold) — used by the salary benchmark feature.
# Same connection contract as cicero_mcp.
POSTGRES_SERVER=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
POSTGRES_DATABASE_GOLD=db_gold

# Cicero MCP server — placement intelligence (credentials, benchmarks)
# Dev: run cicero locally with SKIP_AUTH=true on port 3001
CICERO_URL=http://localhost:3001/mcp
SKIP_AUTH_TO_CICERO=true

# Production only — Azure service principal for cicero auth
# CICERO_URL=https://<container-app>.azurecontainerapps.io/mcp
# CICERO_APP_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# SKIP_AUTH_TO_CICERO=false
