# ---------------------------------------------------------------------------
# Pitchdecker environment variables
# Copy this file to .env.local and fill in real values.
# ---------------------------------------------------------------------------

# MongoDB — pitchdecker database (decks, sections, candidates)
MONGODB_CONNECTION_STRING=

# Algolia — consultant directory search
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_CDN_BASE=

# Anthropic — AI panel (analysis, suggestions, chat)
ANTHROPIC_API_KEY=

# AssemblyAI — voice note transcription
ASSEMBLYAI_API_KEY=

# PostgreSQL (db_gold) — used by the salary benchmark feature.
# Same connection contract as cicero_mcp.
POSTGRES_SERVER=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
POSTGRES_DATABASE_GOLD=db_gold
